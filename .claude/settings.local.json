{
  "permissions": {
    "allow": [
      "Bash(grep -rn \"App\\\\\\\\\\\\\\\\Invoice\\\\\\\\\\\\\\\\Entity\\\\\\\\\" src/Infrastructure/Persistence/)",
      "Bash(vendor/bin/psalm)",
      "Bash(vendor/bin/phpunit Tests/Unit/Invoice/Entity/ --no-coverage)",
      "Bash(php c:/wamp64/www/invoice/vendor/bin/phpunit c:/wamp64/www/invoice/Tests/Unit/ --no-coverage)",
      "Bash(c:/wamp64/www/invoice/node_modules/.bin/sass --version)",
      "Bash(npx sass *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File \".claude\\sync-schema.ps1\"",
            "timeout": 45,
            "statusMessage": "Syncing Cycle ORM schema..."
          }
        ]
      }
    ]
  }
}
