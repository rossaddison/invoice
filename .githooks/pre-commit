#!/bin/sh
# Rebuild all TypeScript IIFE bundles before every commit so compiled
# output is never stale relative to source files.

echo "[pre-commit] Building TypeScript IIFE..."
npm run build:typescript:prod
if [ $? -ne 0 ]; then
    echo "[pre-commit] TypeScript build FAILED — commit aborted."
    exit 1
fi

echo "[pre-commit] Building auth TypeScript..."
npm run build:typescript:auth
if [ $? -ne 0 ]; then
    echo "[pre-commit] Auth TypeScript build FAILED — commit aborted."
    exit 1
fi

git add src/Invoice/Asset/rebuild/js/invoice-typescript-iife.js \
        src/Invoice/Asset/rebuild/js/invoice-typescript-iife.min.js \
        src/Auth/Asset/rebuild/js/keypad_copy_to_clipboard-iife.js

echo "[pre-commit] IIFE rebuilt and staged."
