<?php

declare(strict_types=1);

use Yiisoft\Html\Html as H;
use Yiisoft\FormModel\Field;

/**
 * @var App\Invoice\CustomField\CustomFieldForm $field_form
 * @var App\Invoice\Entity\CustomField $custom_field
 * @var App\Widget\Button $button
 * @var Yiisoft\Translator\TranslatorInterface $translator
 * @var Yiisoft\Router\FastRoute\UrlGenerator $urlGenerator
 * @var array $custom_values
 * @var array $custom_values_types
 * @var string $csrf
 */
$customFieldId = $custom_field->getId();

echo H::openTag('form', ['method' => 'post']);
 echo H::tag('input', '', ['type' => 'hidden', 'name' => '_csrf', 'value' => $csrf]); //1
 echo H::openTag('div', ['id' => 'headerbar']); //1
  echo H::openTag('div', ['class' => 'container py-5 h-100']); //2
   echo H::openTag('div', ['class' =>
     'row d-flex justify-content-center align-items-center h-100']); //3
    echo H::openTag('div', ['class' =>
      'col-12 col-md-8 col-lg-6 col-xl-8']); //4
     echo H::openTag('div', ['class' =>
       'card border border-dark shadow-2-strong rounded-3']); //5
      echo H::openTag('div', ['class' => 'card-header']); //6
       echo H::openTag('h1', ['class' => 'headerbar-title']);
        echo $translator->translate('custom.values');
       echo H::closeTag('h1');
       echo H::openTag('div', ['class' => 'headerbar-item pull-right']); //7
        echo H::openTag('div', ['class' => 'btn-group btn-group-sm']); //8
         echo H::openTag('a', [
          'class' => 'btn btn-default',
          'href' => $urlGenerator->generate('customfield/index'),
          ]); //9
          echo H::openTag('i', ['class' => 'fa fa-arrow-left']); //10
          echo H::closeTag('i'); ///10
          echo $translator->translate('back');
         echo H::closeTag('a'); //9
         echo H::openTag('a', [
           'class' => 'btn btn-primary',
           'href' => $urlGenerator->generate('customvalue/new', ['id' => $customFieldId]),
         ]);
          echo H::openTag('i', ['class' => 'fa fa-plus']);
          echo H::closeTag('i');
          echo $translator->translate('new');
         echo H::closeTag('a'); //9
        echo H::closeTag('div'); //8
       echo H::closeTag('div'); //7
       echo H::openTag('div', ['id' => 'content']); //7
        echo H::openTag('div', ['class' => 'row']); //8
         echo H::openTag('div', ['class' =>
           'col-xs-12 col-md-6 col-md-offset-3']); //9
          echo H::openTag('div', ['class' => 'form-group']); //10
           echo Field::text($field_form, 'label')
             ->label($translator->translate('field'))
             ->addInputAttributes([
             'class' => 'form-control form-control-lg',
             'disabled' => 'disabled',
             'id' => 'label',
             ])
             ->value(H::encode($field_form->getLabel()))
             ->render();
          echo H::closeTag('div'); //10
          $optionsDataType = [];
          /**
           * @var string $type
           */
          foreach ($custom_values_types as $type) {
              $alpha = str_replace('-', '.', strtolower($type));
              $optionsDataType[$type] = $translator->translate('' . $alpha . '');
          }
          echo H::openTag('div', ['class' => 'form-group']); //10
           echo Field::select($field_form, 'type')
           ->label($translator->translate('type'))
           ->addInputAttributes([
              'class' => 'form-control form-control-lg',
              'id' => 'type',
              'disabled' => 'disabled',
           ])
           ->optionsData($optionsDataType)
           ->render(); //11
          echo H::closeTag('div'); //10
          echo H::openTag('div', ['class' => 'form-group']); //10
           echo H::openTag('table', ['class' => 'table table-bordered']); //11
            echo H::openTag('thead');
             echo H::openTag('tr');
              echo H::openTag('th');
               echo $translator->translate('id');
              echo H::closeTag('th');
              echo H::openTag('th');
               echo $translator->translate('label');
              echo H::closeTag('th');
              echo H::openTag('th');
               echo $translator->translate('options');
              echo H::closeTag('th');
             echo H::closeTag('tr');
            echo H::closeTag('thead');
            echo H::openTag('tbody'); //12
             /**
              * @var App\Invoice\Entity\CustomValue $custom_value
              */
             foreach ($custom_values as $custom_value) {
             echo H::openTag('tr');
              echo H::openTag('td');
               echo H::encode($custom_value->getId());
              echo H::closeTag('td');
              echo H::openTag('td');
               echo H::encode($custom_value->getValue());
              echo H::closeTag('td');
              echo H::openTag('td');
               echo H::openTag('div', ['class' => 'dropdown']);
                echo H::tag(
                   'button',
                   '⚙' . $translator->translate('options'),
                   [
                    'class' => 'btn btn-secondary'
                    . ' btn-sm dropdown-toggle',
                    'type' => 'button',
                    'id' => 'dropdownMenuButton'
                    . $custom_value->getId(),
                    'data-bs-toggle' => 'dropdown',
                    'aria-expanded' => 'false',
                   ],
                 );
                 echo H::openTag('ul', [
                   'class' => 'dropdown-menu',
                   'aria-labelledby' => 'dropdownMenuButton'
                   . $custom_value->getId()]);
                  echo H::openTag('li');
                   echo H::tag(
                     'a',
                     '👁️ ' . $translator->translate('view'),
                     [
                        'class' => 'dropdown-item',
                        'href' => $urlGenerator->generate('customvalue/view',
                        [
                            'id' => $custom_value->getId()]),
                            'style' => 'text-decoration:none',
                        ],
                     );
                  echo H::closeTag('li');
                  echo H::openTag('li');
                   echo H::tag(
                       'a',
                       '🖉 ' . $translator->translate('edit'),
                       [
                        'class' => 'dropdown-item',
                        'href' => $urlGenerator->generate('customvalue/edit',
                            ['id' => $custom_value->getId()]),
                        'style' => 'text-decoration:none',
                       ],
                      );
                  echo H::closeTag('li');
                  echo H::openTag('li');
                   echo H::tag(
                       'a',
                       '❌ ' . $translator->translate('delete'),
                        [
                         'class' => 'dropdown-item text-danger',
                         'href' => $urlGenerator->generate('customvalue/delete', ['id' => $custom_value->getId()]),
                         'style' => 'text-decoration:none',
                         'onclick' => "return confirm('"
                            . addslashes(
                                $translator->translate('delete.record.warning'))
                                . "')",
                             ],
                         );
                  echo H::closeTag('li');
                 echo H::closeTag('ul');
                echo H::closeTag('div');
              echo H::closeTag('td');
             echo H::closeTag('tr');
            };
            echo H::closeTag('tbody');
           echo H::closeTag('table'); //11
          echo H::closeTag('div');   //10
         echo H::closeTag('div');   //9
        echo H::closeTag('div');   //8
       echo H::closeTag('div');   //7
      echo H::closeTag('div');   //6
     echo H::closeTag('div');   //5
    echo H::closeTag('div');   //4
   echo H::closeTag('div');   //3
  echo H::closeTag('div');   //2
 echo H::closeTag('div');   //1
echo H::closeTag('form');  //0
