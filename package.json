{
  "name": "yii3-i",
  "version": "1.0.0",
  "description": "Yii3 Invoice",
  "type": "module",
  "dependencies": {
    "@angular/compiler": "22.0.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bs5-lightbox": "^1.8.5",
    "clipboard": "^2.0.11",
    "flag-icons": "^7.5.0",
    "govuk-frontend": "^6.2.0",
    "hono": ">=4.12.26",
    "htmx.org": "^2.0.10",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "22.0.4",
    "@angular/common": "22.0.2",
    "@angular/compiler-cli": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@babel/core": "8.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "minimatch": ">=10.2.5",
    "npm-check-updates": "^22.2.7",
    "picomatch": "^4.0.4",
    "prettier": "^4.0.0-alpha.13",
    "rollup": ">=4.62.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "//": "=== IMPORTANT WARNING ===",
    "//preinstall": "⚠️  WARNING: Do not run 'npm install' without reviewing Angular setup! This may conflict with legacy TypeScript configuration.",
    "//info": "📝 Use 'npx ng new' for fresh Angular projects or 'npx ng add' to add Angular to existing projects",
    "//migration": "🔄 This setup integrates Angular with existing Yii3 TypeScript. Review tsconfig.json and angular.json before installing.",
    "//dependency-note": "⚠️ Angular packages use exact versions (no ^) to prevent peer dependency conflicts. The .npmrc file handles this automatically. If issues persist, run: 'npm cache clean --force && rm -rf node_modules package-lock.json && npm install'",
    "build": "npm run build:all",
    "build:all": "npm run build:css && npm run build:typescript && npm run build:angular",
    "build:css": "sass src/Invoice/Asset/invoice/scss/style.scss src/Invoice/Asset/invoice/css/style.css --style=expanded --no-source-map",
    "build:css:prod": "sass src/Invoice/Asset/invoice/scss/style.scss src/Invoice/Asset/invoice/css/style.css --style=compressed --no-source-map",
    "build:typescript": "npm run build:typescript:prod",
    "build:typescript:dev": "node node_modules/esbuild/bin/esbuild src/typescript/index.ts --bundle --outfile=src/Invoice/Asset/rebuild/js/invoice-typescript-iife.js --target=es2024 --format=iife --global-name=InvoiceApp --sourcemap --supported:const=true",
    "build:typescript:auth": "node node_modules/esbuild/bin/esbuild src/Auth/Asset/keypad-copy-to-clipboard.ts --bundle --platform=browser --outfile=src/Auth/Asset/rebuild/js/keypad-copy-to-clipboard-iife.js --target=es2024 --format=iife --minify --supported:const-and-let=true",
    "build:typescript:prod": "node node_modules/esbuild/bin/esbuild src/typescript/index.ts --bundle --outfile=src/Invoice/Asset/rebuild/js/invoice-typescript-iife.js --target=es2024 --format=iife --global-name=InvoiceApp --minify --supported:const-and-let=true && node node_modules/esbuild/bin/esbuild src/typescript/index.ts --bundle --outfile=src/Invoice/Asset/rebuild/js/invoice-typescript-iife.min.js --target=es2024 --format=iife --global-name=InvoiceApp --minify --supported:const-and-let=true",
    "build:typescript:watch": "npm run build:typescript:dev -- --watch",
    "prepare": "git config core.hooksPath .githooks",
    "build:angular": "ng build --configuration production",
    "build:angular:dev": "ng build",
    "build:dev": "npm run build:typescript:dev && npm run build:angular:dev",
    "build:prod": "npm run build:typescript:prod && npm run build:angular",
    "build:watch": "npm run build:typescript:watch",
    "ng": "ng",
    "ng:build": "ng build",
    "ng:serve": "ng serve",
    "ng:test": "ng test",
    "ng:lint": "ng lint",
    "angular:setup": "npx ng add @angular/pwa && npx ng add @angular/material",
    "angular:generate-component": "ng generate component",
    "angular:generate-service": "ng generate service",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint src/typescript/**/*.ts",
    "lint:fix": "eslint src/typescript/**/*.ts --fix",
    "lint:angular": "ng lint",
    "format": "prettier --write src/typescript/**/*.ts",
    "format:check": "prettier --check src/typescript/**/*.ts",
    "security:quick": "snyk test --severity-threshold=high",
    "security:full": "snyk test && snyk code test",
    "security:deps": "snyk test",
    "dev": "npm run build:watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "upgrade:check": "npx ncu --target minor",
    "upgrade:safe": "npx ncu --target patch -u && npm install",
    "upgrade:minor": "npx ncu --target minor -u && npm install",
    "upgrade:major": "npx ncu --target greatest -i",
    "generate:docs": "typedoc src/typescript/ --out docs/api",
    "clean": "rm -rf src/Invoice/Asset/rebuild/js/invoice-typescript-iife.js*",
    "clean:angular": "rm -rf dist/ && rm -rf .angular/",
    "es2024:verify": "node -e \"console.log('ES2024 features available:', Object.hasOwn({}, 'test'), Array.prototype.toSorted ? 'toSorted' : 'missing', Object.groupBy ? 'groupBy' : 'missing', Promise.withResolvers ? 'withResolvers' : 'missing')\"",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "overrides": {
    "webpack-dev-server": "^5.2.4",
    "uuid": ">=11.1.1",
    "esbuild": "^0.28.1",
    "vite": ">7.3.4",
    "@angular/compiler-cli": {
      "@babel/core": "^7.29.6"
    }
  },
  "license": "BSD-3-Clause",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "yii3",
    "invoice",
    "typescript",
    "es2024",
    "bootstrap5",
    "govuk-frontend"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rossaddison/invoice.git"
  },
  "bugs": {
    "url": "https://github.com/rossaddison/invoice/issues"
  },
  "homepage": "https://github.com/rossaddison/invoice#readme"
}
